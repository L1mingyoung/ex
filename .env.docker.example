# Copy this file to .env.docker, then fill secrets.

DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=companion

# Host port mappings
PORT=3000
DB_PORT=54321
EMBEDDING_PORT=8000

DB_LOGGING=false

# Required for LLM replies.
DEEPSEEK_API_KEY=sk-xxxxxxxx

# Use 0 for the real ONNX embedding model.
# Use 1 only when you want to test the stack before downloading the model.
MOCK_EMBEDDING=0
EMBEDDING_MODEL_PATH=/app/models/jina-embeddings-v2-base-zh.onnx
EMBEDDING_TOKENIZER_PATH=/app/models/tokenizer.json
